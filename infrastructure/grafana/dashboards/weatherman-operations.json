{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Tile Latency",
      "type": "row"
    },
    {
      "title": "Tile Latency p50 / p95 / p99",
      "description": "HTTP request latency percentiles for tile endpoints over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"/tiles/.*\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"/tiles/.*\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"/tiles/.*\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Tile Latency Heatmap",
      "description": "Distribution of tile request latencies",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Oranges" },
        "cellGap": 1
      },
      "targets": [
        {
          "expr": "sum(increase(http_request_duration_seconds_bucket{endpoint=~\"/tiles/.*\"}[$__rate_interval])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Pipeline Status",
      "type": "row"
    },
    {
      "title": "Pipeline Run Outcomes",
      "description": "Success vs failure pipeline runs per model over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*success.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*failure.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "increase(pipeline_runs_total[$__rate_interval])",
          "legendFormat": "{{model}} — {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Pipeline Step Duration",
      "description": "Duration of individual pipeline steps (p50/p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(pipeline_step_duration_seconds_bucket[$__rate_interval])) by (step, le))",
          "legendFormat": "{{step}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(pipeline_step_duration_seconds_bucket[$__rate_interval])) by (step, le))",
          "legendFormat": "{{step}} p95",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Data Freshness",
      "type": "row"
    },
    {
      "title": "Data Freshness by Model",
      "description": "Time since last successful publish per model. Green < 2h, Yellow < 4h, Red >= 4h",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 19 },
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 28800,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 7200 },
              { "color": "red", "value": 14400 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "time() - data_last_publish_timestamp_seconds",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "Error Rates",
      "type": "row"
    },
    {
      "title": "HTTP Error Rate by Endpoint",
      "description": "Rate of 4xx and 5xx responses per endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[$__rate_interval])) by (endpoint)",
          "legendFormat": "5xx — {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..\"}[$__rate_interval])) by (endpoint)",
          "legendFormat": "4xx — {{endpoint}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Pipeline Errors by Step",
      "description": "Rate of pipeline step errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          }
        }
      },
      "targets": [
        {
          "expr": "rate(pipeline_errors_total[$__rate_interval])",
          "legendFormat": "{{step}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 104,
      "title": "Resource Utilization",
      "type": "row"
    },
    {
      "title": "CPU Usage",
      "description": "Process CPU time from default Prometheus collectors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 35 },
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[$__rate_interval])",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "description": "Resident memory from default Prometheus collectors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 35 },
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Open File Descriptors",
      "description": "Open FDs vs limit from default Prometheus collectors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 35 },
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "process_open_fds",
          "legendFormat": "open",
          "refId": "A"
        },
        {
          "expr": "process_max_fds",
          "legendFormat": "limit",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 105,
      "title": "Active Connections",
      "type": "row"
    },
    {
      "title": "Active HTTP Connections",
      "description": "In-flight HTTP requests",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 44 },
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30
          }
        }
      },
      "targets": [
        {
          "expr": "http_active_connections",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Rate by Endpoint",
      "description": "Total request throughput per endpoint",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 44 },
      "id": 12,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[$__rate_interval])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["weatherman", "operations"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Weatherman Operations",
  "uid": "weatherman-ops",
  "version": 1
}
