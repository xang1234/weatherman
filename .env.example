# Core AIS settings
AIS_DB_PATH=/data/ais.duckdb
AIS_BACKEND=legacy_parquet
AIS_TENANT_ID=default

# Neptune archival bridge
NEPTUNE_STORE_ROOT=/data/neptune
NEPTUNE_SOURCES=noaa
NEPTUNE_MERGE=best
NEPTUNE_BBOX=
NEPTUNE_MMSI=
NEPTUNE_RAW_POLICY=metadata
NEPTUNE_OVERWRITE=false
NEPTUNE_API_KEYS_JSON=

# Neptune live ingest
COMPOSE_PROFILES=
NEPTUNE_LIVE_SOURCE=aisstream
NEPTUNE_LIVE_LANDING_DIR=/data/neptune-live
NEPTUNE_LIVE_BBOX=
NEPTUNE_LIVE_MMSI=
NEPTUNE_LIVE_MAX_MESSAGES=
NEPTUNE_LIVE_CLEANUP=false
NEPTUNE_LIVE_FLUSH_INTERVAL=60
NEPTUNE_LIVE_API_KEY=
